{
  "name": "@dunya/api",
  "version": "0.2.0",
  "private": true,
  "description": "Dünya Analiz — NestJS API (modüler monolit + worker)",
  "scripts": {
    "dev": "nest start --watch",
    "dev:worker": "node --watch --import tsx src/worker.ts",
    "dev:scheduler": "node --watch --import tsx src/scheduler.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:scheduler": "node dist/scheduler.js",
    "migrate": "node --import tsx src/database/migrate.ts",
    "seed": "node --import tsx src/database/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/database/*.spec.ts src/modules/auth/*.spec.ts src/modules/content/*.spec.ts src/modules/embedding/*.spec.ts src/modules/predictions/*.spec.ts src/workers/*.spec.ts",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters"
  },
  "dependencies": {
    "@dunya/contracts": "0.2.0",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.2.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "ioredis": "5.10.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
