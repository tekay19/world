# ---- PostgreSQL ----
POSTGRES_USER=dunya
POSTGRES_PASSWORD=dunya
POSTGRES_DB=dunya
POSTGRES_PORT=5432
# API'nin kullandığı tam bağlantı dizesi
DATABASE_URL=postgres://dunya:dunya@localhost:5432/dunya
# Aynı rolün toplam replika sayısı; süreç başına havuz payı buna göre hesaplanır.
PROCESS_REPLICA_COUNT=1
# İsteğe bağlı açık süreç başı sınır. PgBouncer kullanırken dağıtım bazında ayarlayın.
# PG_POOL_MAX=10

# ---- Redis (kuyruk + cache + rate limit) ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- API ----
API_PORT=4000
# Virgülle ayrılmış izinli origin listesi (CORS)
CORS_ORIGINS=http://localhost:3000

# ---- BYOK master key ----
# Kullanıcı LLM anahtarlarını (OpenAI/Claude/Gemini/Kimi/NVIDIA) AES-256-GCM ile şifreler.
# 32 byte'ı base64 olarak verin:  openssl rand -base64 32
# Boş bırakılırsa: DEV'de .secrets/dev-master.key otomatik üretilir (git ignore).
#                  PRODUCTION'da bu değişken ZORUNLUDUR.
# DİKKAT: repoya KOMMİTLEMEYİN. Sadece .env içinde tutun.
LLM_MASTER_KEY=

# ---- Kimlik doğrulama ----
# Üretimde en az 32 karakterlik rastgele bir secret/secret-manager değeri kullanın.
# Boş bırakılırsa yalnız development'ta .secrets/dev-jwt.key üretilir.
JWT_SECRET=
JWT_ACCESS_TTL=900

# ---- Embedding servisi (S3) ----
EMBEDDING_URL=http://localhost:8000
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:4000
FRED_API_KEY=
TWELVE_DATA_API_KEY=
METACULUS_TOKEN=
